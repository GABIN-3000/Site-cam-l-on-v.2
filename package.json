{
  "name": "site-cameleon-v2",
  "version": "2.0.0",
  "private": true,
  "description": "Dynamic multi-mode admin dashboard for community platforms",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:migrate": "cd packages/db && npm run migrate",
    "db:seed": "cd packages/db && npm run seed",
    "db:studio": "cd packages/db && npm run studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
