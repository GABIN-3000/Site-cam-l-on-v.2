{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env"],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["build"]
    },
    "lint": {
      "outputs": [".eslint-cache/**"]
    },
    "type-check": {
      "outputs": [".tsc-out/**"]
    }
  }
}
